    },
    "Swipe to turn pages. Tap a slot to collect it; press and hold to manage copies." : {
      "localizations" : {
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deslize para virar as páginas. Toque numa figurinha para colar; segure para ajustar as repetidas."
          }
        }
      }
    },
    "Switch at the top of the Album and Duplicates tabs to track the FIFA Panini Collection app too." : {
      "extractionState" : "stale",
      "localizations" : {
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Troque no topo das abas Álbum e Repetidas para acompanhar também o app FIFA Panini Collection."
          }
        }
      }
    },
    "Switzerland" : {
      "extractionState" : "stale",
      "localizations" : {
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suíça"
          }
        }
      }
    },
    "Tap + to add a sticker you have spares of. Anything you own more than once shows up here." : {
      "extractionState" : "stale",
      "localizations" : {
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toque em + para adicionar uma figurinha repetida. Tudo que você tem mais de uma vez aparece aqui."
          }
        }
      }
    },
    "Tap any sticker to mark it collected. Swipe a row (or press and hold a page slot) to manage spare copies." : {
      "extractionState" : "stale",
      "localizations" : {
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toque em qualquer figurinha para marcá-la como colada. Deslize uma linha (ou segure um espaço na página) para ajustar as repetidas."
          }
        }
      }
    },
    "Team" : {
      "extractionState" : "stale",
      "localizations" : {
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seleção"
          }
        }
      }
    },
    "Team Logo" : {
      "extractionState" : "stale",
      "localizations" : {
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escudo"
